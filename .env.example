# ─── Database ──────────────────────────────────────────────────────────────────
# Connection string used by the backend application
DATABASE_URL=postgres://carpost:carpost_dev@192.168.1.164:5434/carpostall
# Password for the Postgres container (used in docker-compose)
POSTGRES_PASSWORD=carpost_dev

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── JWT ──────────────────────────────────────────────────────────────────────
# REQUIRED — set strong, unique secrets in production
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-in-production-too

# ─── Firebase (optional) ─────────────────────────────────────────────────────
# Service account key JSON string — required for push notifications
FIREBASE_SERVICE_ACCOUNT_KEY=

# ─── Sentry (optional) ───────────────────────────────────────────────────────
# Error tracking DSN — leave empty to disable
SENTRY_DSN=

# ─── Docker (remote host) ────────────────────────────────────────────────────
DOCKER_HOST=tcp://192.168.1.164:2375
